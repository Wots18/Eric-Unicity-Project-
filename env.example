# ---- Sphere AutoVend configuration ----
# Copy this file to ".env" (it is gitignored) and adjust as you like.

# Network preset. "testnet" points at the v2 testnet2 gateway.
NETWORK=testnet

# The @nametag your agent will register and receive orders on.
# Must be unique on the network (3-20 chars, lowercase letters/numbers/_/-).
# If "autovend" is taken, pick your own, e.g. ra-autovend.
NAMETAG=autovend

# testnet2 gateway API key. This is the PUBLIC testnet key and is NOT a secret
# (Unicity publish it themselves). Safe to keep here. A MAINNET key would be
# a real secret — never commit one of those.
UNICITY_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590

# Token symbol the shop prices in.
COIN_SYMBOL=UCT

# How much to self-mint into the treasury on first run (human units).
MINT_AMOUNT=1000

# How long (ms) to wait for a buyer to approve a payment before cancelling.
PAYMENT_TIMEOUT_MS=120000

# Optional: pin a wallet mnemonic so restarts keep the same identity even if
# the ./data folder is wiped. Leave blank to auto-generate on first run.
# WALLET_MNEMONIC=
